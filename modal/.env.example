# Required — admin login password (use a long random string in production)
MODAL_ADMIN_PASSWORD=change-me-to-a-strong-password

# Required — secret for signing session cookies (32+ random chars)
MODAL_SESSION_SECRET=change-me-to-a-long-random-secret

# Optional — override tool URLs (defaults work for Halloway stack)
MODAL_SITE_URL=https://hallowayassociates.com
MODAL_GA_URL=https://analytics.google.com/
MODAL_GSC_URL=https://search.google.com/search-console
MODAL_EMAIL_AUTOMATION_SHEET_URL=https://docs.google.com/spreadsheets/d/1tmJS2EiLdZr9hdYNA3gJHijFInU3vAae2urP-em4_AE/edit?gid=0#gid=0
